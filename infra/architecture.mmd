    classDef orch fill:#7c3aed,stroke:#3b0764,color:#fff
    classDef agent fill:#a855f7,stroke:#4c1d95,color:#fff
    classDef azai fill:#0078d4,stroke:#003e7c,color:#fff
    classDef data fill:#0f766e,stroke:#064e3b,color:#fff
    classDef ops fill:#475569,stroke:#0f172a,color:#fff
    classDef ext fill:#b45309,stroke:#7c2d12,color:#fff
