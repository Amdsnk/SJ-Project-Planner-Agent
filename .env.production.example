# =============================================================================
# SJ Project Planner Agent — production environment template
# -----------------------------------------------------------------------------
# Copy to ".env.production" and fill in real values. Do NOT commit the filled
# copy. Every value listed here is consumed by ``backend/app/config.py`` (or
# read directly by ``app/services/blob_storage.py`` / ``cosmos_events.py``).
# =============================================================================

# ---------- App ----------
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true
# Comma-separated list. Set this to the public origin(s) of the SPA.
CORS_ORIGINS=https://sjplanner.example.com

# ---------- Database (Azure Database for PostgreSQL Flexible Server) ----------
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg2://sjplanner:REPLACE_ME@REPLACE_ME.postgres.database.azure.com:5432/sjplanner?sslmode=require

# ---------- Auth ----------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_ME_WITH_RANDOM_48_CHARS
JWT_TTL_MINUTES=480
# Bootstrap admin (only used the very first time the DB is empty).
[email protected]
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD
BOOTSTRAP_ORG_NAME=SJ Group

# ---------- Microsoft Entra ID (Azure AD) — optional but recommended ----------
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_AUDIENCE=api://sj-planner

# ---------- Azure OpenAI / Foundry ----------
AZURE_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------- Azure AI Search (optional) ----------
AZURE_SEARCH_ENDPOINT=https://REPLACE_ME.search.windows.net
AZURE_SEARCH_API_KEY=REPLACE_ME
AZURE_SEARCH_INDEX=sj-planner-notes

# ---------- Azure Blob Storage (note attachments) ----------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=REPLACE_ME;AccountKey=REPLACE_ME;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=sj-planner-attachments

# ---------- Azure Cosmos DB (optional event store mirror) ----------
COSMOS_CONNECTION_STRING=AccountEndpoint=https://REPLACE_ME.documents.azure.com:443/;AccountKey=REPLACE_ME==;
COSMOS_DATABASE=sj-planner
COSMOS_CONTAINER=audit-events

# ---------- Application Insights ----------
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=REPLACE_ME;IngestionEndpoint=https://REPLACE_ME.in.applicationinsights.azure.com/

# ---------- Outbound webhooks (Power Automate) ----------
WEBHOOK_URL_DRAFT_CREATED=https://prod-XX.southeastasia.logic.azure.com:443/workflows/REPLACE_ME/triggers/manual/paths/invoke?...
WEBHOOK_URL_DRAFT_APPROVED=https://prod-XX.southeastasia.logic.azure.com:443/workflows/REPLACE_ME/triggers/manual/paths/invoke?...
# HMAC secret used to sign outbound webhook bodies; verify on the Power Automate side.
WEBHOOK_SIGNING_SECRET=REPLACE_ME_WITH_RANDOM_32_CHARS

# ---------- PII redaction ----------
REDACT_PII=true
